{
  "name": "crcl",
  "private": true,
  "scripts": {
    "agent:source": "cargo run --release -- agent-context --profile source",
    "agent:source:json": "cargo run --release -- agent-context --profile source --format json",
    "agent:financial": "cargo run --release -- agent-context --profile financial",
    "agent:financial:json": "cargo run --release -- agent-context --profile financial --format json",
    "agent:regulatory": "cargo run --release -- agent-context --profile regulatory",
    "agent:competition": "cargo run --release -- agent-context --profile competition",
    "agent:platform": "cargo run --release -- agent-context --profile platform",
    "agent:risk": "cargo run --release -- agent-context --profile risk",
    "agent:autoresearch": "cargo run --release -- agent-context --profile autoresearch",
    "data:init": "cargo run --release -- init-db",
    "data:collect": "cargo run --release -- collect --source all",
    "data:summary": "cargo run --release -- summary",
    "data:missing": "cargo run --release -- missing",
    "lint:md": "markdownlint \"docs/**/*.md\" --ignore \"docs/archive/**/*.md\"",
    "lint:rs": "cargo fmt --check && cargo clippy --release -- -D warnings",
    "test:rs": "cargo test --release",
    "verify": "npm run lint:md && npm run lint:rs && npm run test:rs"
  },
  "devDependencies": {
    "markdownlint-cli": "^0.48.0"
  }
}
